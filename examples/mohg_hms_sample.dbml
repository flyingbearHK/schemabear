// Generated by er-core 0.1.0
// Project: MOHG HMS Sample

Table PROPERTY {
  property_code varchar [pk, not null]
  property_name varchar
  brand_code varchar
  timezone varchar
  currency_code varchar
}

Table BUILDING {
  building_key varchar [pk, not null]
  property_code varchar [note: 'FK']
  building_name varchar
  floor_count int
}

Table ROOM {
  room_key varchar [pk, not null]
  property_code varchar [note: 'FK']
  building_key varchar [note: 'FK']
  room_number varchar
  room_type_code varchar
  is_statistical boolean
}

Table RATE_CODE {
  rate_code varchar [pk, not null]
  property_code varchar [note: 'FK']
  rate_name varchar
  currency_code varchar
}

Table MARKET_SEGMENT {
  market_segment_code varchar [pk, not null]
  property_code varchar [note: 'FK']
  segment_name varchar
  segment_group varchar
}

Table GUEST {
  guest_id varchar [pk, not null]
  first_name varchar
  last_name varchar
  email varchar
  vip_code varchar
}

Table RESERVATION {
  reservation_id varchar [pk, not null]
  property_code varchar [note: 'FK']
  guest_id varchar [note: 'FK']
  market_segment_code varchar [note: 'FK']
  arrival_date date
  departure_date date
  status_code varchar
  confirmation_number varchar [unique]
}

Table RESERVATION_STAY_NIGHT {
  stay_night_id varchar [pk, not null]
  reservation_id varchar [note: 'FK']
  room_key varchar [note: 'FK']
  rate_code varchar [note: 'FK']
  business_date date
  room_revenue decimal
  room_nights decimal
}

Table FOLIO {
  folio_id varchar [pk, not null]
  reservation_id varchar [note: 'FK']
  guest_id varchar [note: 'FK']
  folio_type varchar
  status_code varchar
}

Table FOLIO_POSTING {
  posting_id varchar [pk, not null]
  folio_id varchar [note: 'FK']
  business_date date
  transaction_code varchar
  amount decimal
  currency_code varchar
}

// contains
Ref: BUILDING.property_code > PROPERTY.property_code
// inventories
Ref: ROOM.(property_code, building_key) > PROPERTY.property_code
// houses
Ref: ROOM.(property_code, building_key) > BUILDING.building_key
// offers
Ref: RATE_CODE.property_code > PROPERTY.property_code
// classifies
Ref: MARKET_SEGMENT.property_code > PROPERTY.property_code
// books
Ref: RESERVATION.(property_code, guest_id, market_segment_code) > GUEST.guest_id
// hosts
Ref: RESERVATION.(property_code, guest_id, market_segment_code) > PROPERTY.property_code
// expands
Ref: RESERVATION_STAY_NIGHT.(reservation_id, room_key, rate_code) > RESERVATION.reservation_id
// occupies
Ref: RESERVATION_STAY_NIGHT.(reservation_id, room_key, rate_code) > ROOM.room_key
// prices
Ref: RESERVATION_STAY_NIGHT.(reservation_id, room_key, rate_code) > RATE_CODE.rate_code
// segments
Ref: RESERVATION.(property_code, guest_id, market_segment_code) > MARKET_SEGMENT.market_segment_code
// bills
Ref: FOLIO.(reservation_id, guest_id) > RESERVATION.reservation_id
// posts
Ref: FOLIO_POSTING.folio_id > FOLIO.folio_id
// pays
Ref: FOLIO.(reservation_id, guest_id) > GUEST.guest_id
